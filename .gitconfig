[core]
  pager = delta
  autoCRLF = false
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true   # n / N で diff セクション間ジャンプ
  light = true      # Ghostty の TokyoNight Day (light) に合わせる
[include]
  path = ~/.gitconfig_user
[include]
  # Optional: profile-local extras (e.g. SSH/GPG commit signing).
  # Missing path is silently ignored by git, so this is no-op when not set up.
  path = ~/.gitconfig_signing
[alias]
  gl = log --pretty=format:\"%C(red)%h%Creset %C(cyan)<%an>%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%Creset\" --abbrev-commit --date=relative --graph
[filter "lfs"]
  clean = git lfs clean %f
  smudge = git lfs smudge %f
  required = true
[push]
  default = current
  autoSetupRemote = true
[init]
  defaultBranch = main
[diff]
  algorithm = histogram
  colorMoved = default
[merge]
  conflictStyle = zdiff3
[fetch]
  prune = true
[pull]
  ff = only
[rerere]
  enabled = true
[branch]
  sort = -committerdate
[commit]
	template = ~/.commit_template
