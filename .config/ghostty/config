# Ghostty config
# https://ghostty.org/docs/config
# 設定全項目: ghostty +show-config --default

# === Theme ===
# tokyonight.nvim の Day variant (light) と揃える
theme = TokyoNight Day

# === Font ===
# Nerd Font (nvim devicons / starship アイコン用)。Brewfile の cask で導入。
font-family = "JetBrainsMono Nerd Font"
font-size = 14

# === Cursor ===
cursor-style = block
cursor-style-blink = false

# === Scrollback ===
scrollback-limit = 100000

# === UX ===
# 改行を含むペーストを確認 (誤実行防止)
clipboard-paste-protection = true
# 入力中はマウスカーソルを隠す
mouse-hide-while-typing = true
# 単一サーフェスを閉じるときの確認ダイアログをスキップ
confirm-close-surface = false

# === macOS ===
macos-titlebar-style = tabs
window-padding-x = 8
window-padding-y = 8
